# Auto-generated by mdp-rs — do not edit; regenerated on each `mdp serve`.
# Source directory: {{SRC_DIR}}

[book]
title = "{{TITLE}}"
authors = ["{{AUTHOR}}"]
language = "{{LANGUAGE}}"
src = "src"

[build]
build-dir = "book"
create-missing = false

[output.html]
# julian.jee is a CSS-only theme — enable via additional-css and default-theme.
default-theme = "julian-jee-dark"
preferred-dark-theme = "julian-jee-dark"
smart-punctuation = true

# Right sidebar (page TOC) is DISABLED — the left sidebar from
# mdbook-pagetoc already includes heading-level TOC, so the right one is redundant.
additional-css = [
    "theme/julian-jee-variables.css",
    "theme/julian-jee-general.css",
    "theme/mdp-breadcrumb.css",
    "theme/pagetoc.css",
]
additional-js = [
    "mermaid.min.js",
    "mermaid-init.js",
    "theme/pagetoc.js",
    "theme/mdp-breadcrumb.js",
]

[output.html.fold]
enable = true
level = 1

[output.html.search]
enable = true
limit-results = 30
use-boolean-and = true
boost-title = 2
boost-hierarchy = 2

# mdbook 0.5+ native admonitions (replaces deprecated mdbook-admonish).
# Admonitions are enabled by default — setting to `false` disables. Default `true`.
# (Boolean form, not table.)

# -------------------- preprocessors --------------------

[preprocessor.pagetoc]

[preprocessor.katex]
after = ["links"]
output = "html"

[preprocessor.mermaid]

[preprocessor.plantuml]
plantuml-cmd = "{{PLANTUML_SERVER}}"
